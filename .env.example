# ── Ports ──────────────────────────────────────────────────────────────────
# Only gateway exposes a port to the host; skill-files/runner use internal expose only.
GATEWAY_PORT=8400
SKILL_FILES_PORT=8100
SKILL_RUNNER_PORT=8200

# ── Ollama ─────────────────────────────────────────────────────────────────
# Windows / macOS Docker Desktop: host.docker.internal resolves to the host.
# Linux (no Docker Desktop): replace with your host IP, or add
#   extra_hosts: ["host.docker.internal:host-gateway"]
#   under agent-gateway in docker-compose.yml
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Model name — must match exactly what `ollama list` shows.
# Recommended: qwen3.5:27b (strong tool-calling, 24GB+ VRAM)
# Alternatives: qwen2.5:7b, qwen2.5-coder:7b (8GB VRAM)
OLLAMA_MODEL=qwen3.5:27b

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Execution timeouts (seconds) ──────────────────────────────────────────
PYTHON_EXEC_TIMEOUT=120
SHELL_EXEC_TIMEOUT=60

# ── Feature flags ──────────────────────────────────────────────────────────
AUTO_GIT_COMMIT=true

# Web search: requires SearXNG + skill-websearch (start with --profile websearch)
ENABLE_WEBSEARCH=false
