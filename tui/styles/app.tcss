/* Local AI Agent TUI — minimalist CLI theme */

Screen {
    background: #0f1115;
    color: #eceff4;
}

#main-container {
    layout: horizontal;
    height: 1fr;
}

#sidebar {
    width: 24;
    min-width: 18;
    background: #12151a;
    border-right: solid #232831;
}

#sidebar.narrow {
    width: 18;
    min-width: 16;
}

#sidebar.collapsed {
    display: none;
}

#chat-area {
    width: 1fr;
    layout: vertical;
}

#sidebar-title {
    dock: top;
    height: 1;
    background: transparent;
    color: #c6ccd3;
    text-style: bold;
    padding: 0 1;
    border-bottom: solid #232831;
}

#conversation-list {
    height: 1fr;
    background: transparent;
}

#conversation-list > .conversation-item {
    height: 3;
    padding: 0 1;
    border-left: tall transparent;
    border-bottom: solid #1b2027;
}

#conversation-list > .conversation-item:hover {
    background: #171b21;
}

#conversation-list > .conversation-item.--highlight {
    background: #171d24;
    border-left: tall #6d8dad;
}

#conversation-list .conversation-copy {
    color: #d7dbe0;
}

#chat-scroll {
    height: 1fr;
    padding: 0 1;
    background: #0f1115;
}

.thinking-block {
    margin: 0 0 0 0;
}

#input-area {
    dock: bottom;
    height: auto;
    min-height: 3;
    max-height: 10;
    padding: 0 1;
    background: #0f1115;
    border-top: solid #232831;
}

#input-area TextArea {
    height: auto;
    min-height: 1;
    max-height: 8;
    background: #151920;
    border: round #2a313b;
    color: #f2f4f7;
}

#input-area .input-hint {
    dock: bottom;
    height: 1;
    color: #7d858f;
    padding: 0 1;
}

#file-explorer-container {
    height: 25%;
    min-height: 5;
    background: #111419;
    border-top: solid #232831;
    display: none;
}

#file-explorer-container.visible {
    display: block;
}

#file-explorer-title {
    dock: top;
    height: 1;
    background: transparent;
    color: #b7bec8;
    padding: 0 1;
    border-bottom: solid #232831;
}

#file-explorer-tree {
    height: 1fr;
    background: transparent;
}

#app-header {
    dock: top;
    height: 1;
    background: #0f1115;
    color: #aeb6c0;
    content-align: center middle;
    text-style: bold;
    border-bottom: solid #232831;
}

#status-bar {
    dock: bottom;
    height: 1;
    background: #0f1115;
    color: #7d858f;
    padding: 0 1;
    border-top: solid #232831;
}

Footer {
    background: #0f1115;
    color: #6f7781;
}

Footer > .footer--key {
    color: #99a5b3;
    background: transparent;
}

Footer > .footer--description {
    color: #6f7781;
}
